# ============================================================
# 穗鈅助手 — 環境設定範例
# ============================================================
# 複製此檔案為 .env 並填入真實值：
#   cp .env.example .env
#
# ⚠️ .env 已加入 .gitignore，絕對不要提交到 Git
# ============================================================

# ------------------------------------------------------------
# 系統
# ------------------------------------------------------------
APP_NAME=sui-yao-agent
APP_VERSION=3.0.0
NODE_ENV=production

# ------------------------------------------------------------
# Telegram Bot
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ------------------------------------------------------------
# LINE Bot（Phase 4）
# ------------------------------------------------------------
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ------------------------------------------------------------
# LLM — 雲端
# ------------------------------------------------------------
OPENAI_API_KEY=
DEFAULT_MODEL=gpt-4o-mini
STRONG_MODEL=gpt-4o

# ------------------------------------------------------------
# LLM — 本地（Ollama）
# ------------------------------------------------------------
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
SCHEDULER_MODEL=ollama/llama3.1:8b

# ------------------------------------------------------------
# Embedding（語意搜尋）
# ------------------------------------------------------------
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ------------------------------------------------------------
# MongoDB
# ------------------------------------------------------------
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=sui-yao-agent

# ------------------------------------------------------------
# 記憶系統
# ------------------------------------------------------------
MEMORY_MAX_COUNT=200
MEMORY_SEARCH_TOP_K=5
MEMORY_MIN_SIMILARITY=0.3
DAILY_LOG_RETENTION_DAYS=30

# ------------------------------------------------------------
# Session（對話歷史）
# ------------------------------------------------------------
SESSION_TOKEN_LIMIT=4000
SESSION_FLUSH_THRESHOLD=0.8
SESSION_MAX_ROUNDS=100

# ------------------------------------------------------------
# Agent 迴圈
# ------------------------------------------------------------
AGENT_MAX_LOOP=10
AGENT_LOOP_TIMEOUT_MS=30000

# ------------------------------------------------------------
# 排程
# ------------------------------------------------------------
SCHEDULER_INTERVAL_MS=60000

# ------------------------------------------------------------
# ERP API
# ------------------------------------------------------------
ERP_API_URL=http://localhost:3000
ERP_TAX_ID=
ERP_BOT_EMAIL=
ERP_BOT_PASSWORD=

# ------------------------------------------------------------
# Email（gog CLI）
# ------------------------------------------------------------
GOG_ACCOUNT=info@sui-yao.com
GOG_BIN_PATH=/opt/homebrew/bin/gog

# ------------------------------------------------------------
# Printer（精臣標籤機）
# ------------------------------------------------------------
PRINTER_API_URL=http://10.0.5.125:3000
PRINTER_API_KEY=
LABEL_WIDTH=40
LABEL_HEIGHT=30

# ------------------------------------------------------------
# Canvas / PDF
# ------------------------------------------------------------
CANVAS_PUBLIC_URL=
CANVAS_DIR=./canvas
PDF_TEMP_DIR=/tmp/sui-yao-pdf

# ------------------------------------------------------------
# 錯誤通知
# ------------------------------------------------------------
ERROR_NOTIFY_ENABLED=true
ERROR_NOTIFY_CHANNEL=telegram
ERROR_MAX_RETRY=3

# ------------------------------------------------------------
# 日誌
# ------------------------------------------------------------
LOG_LEVEL=info
LOG_FILE=logs/sui-yao-agent.log
